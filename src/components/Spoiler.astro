---
interface Props {
  summary?: string
  class?: string
}
const { summary = '显示/隐藏内容', class: className } = Astro.props
---

<!-- Spoiler component - simplified version -->
<details class={`spoiler ${className || ''}`}>
  <summary class="cursor-pointer text-blue-500 hover:text-blue-700">{summary}</summary>
  <div class="mt-2 p-4 bg-gray-100 rounded">
    <slot />
  </div>
</details>
