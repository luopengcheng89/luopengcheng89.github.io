---
interface Props {
  slot: string
}
const { slot } = Astro.props
---

<!-- Spoiler component - simplified version -->
<details class="spoiler" slot={slot}>
  <summary class="cursor-pointer text-blue-500 hover:text-blue-700">显示/隐藏剧透</summary>
  <div class="mt-2 p-4 bg-gray-100 rounded">
    <slot />
  </div>
</details>
